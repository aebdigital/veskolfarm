# SMTP2GO Configuration
# Get your API key from: https://app.smtp2go.com/settings/apikeys
SMTP2GO_API_KEY=your-smtp2go-api-key-here

# Email where contact form submissions are sent (default: info@veskolfarm.sk)
CONTACT_EMAIL=info@veskolfarm.sk

# Sender email (must be verified in SMTP2GO)
SENDER_EMAIL=noreply@veskolfarm.sk
